# Copy this file to backend/.env and update values
# Example (Windows): copy env.example backend\.env

# Flask
SECRET_KEY=change-this-secret
FLASK_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# Feature flags
FORCE_PROXY_API=false

# Optional API keys
VIDEO_DOWNLOAD_API_KEY=
ACOUSTID_API_KEY=

# Optional proxy (leave empty if not used)
HTTP_PROXY=
HTTPS_PROXY=
